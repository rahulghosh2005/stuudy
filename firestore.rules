rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Deny ALL by default — explicit deny-all catch-all.
    // Any collection not explicitly matched below is denied.
    match /{document=**} {
      allow read, write: if false;
    }

    // Users collection:
    // - Any authenticated user can read any profile (needed for Phase 4 follow lists, Phase 5 feed)
    // - A user can only WRITE their own document (PRIV-04)
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Sessions subcollection (users/{uid}/sessions/{sessionId}):
    // - Authenticated users can read any session (Phase 5 will add privacy enforcement)
    // - A user can only create sessions where userId matches their auth uid (PRIV-03)
    // - A user can only update/delete their own sessions
    match /users/{userId}/sessions/{sessionId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    // Subjects subcollection (users/{uid}/subjects/{subjectId}):
    // - Owner-only read and write (personal subject list)
    match /users/{userId}/subjects/{subjectId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
